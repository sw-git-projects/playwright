{
  "compilerOptions": {
    "target": "ES2020", // Set target JavaScript version
    "module": "commonjs", // Module system for Node.js
    "moduleResolution": "node", // Resolve modules like Node.js
    "strict": true, // Enable strict type checking
    "esModuleInterop": true, // Allow default imports from modules without a default export
    "skipLibCheck": true, // Skip type checking of declaration files (for faster compilation)
    "forceConsistentCasingInFileNames": true, // Ensure consistent file name casing
    "outDir": "./dist", // Directory for compiled JavaScript files
    "baseUrl": ".", // Base directory for resolving non-relative module imports
    "types": ["node", "playwright"] // Include Playwright and Node.js type definitions
  },
  "include": [
    "tests/**/*.ts",
    "config/**/*.ts",
    "misc/**/*.ts"
  ],
  "exclude": [
    "node_modules" // Exclude node_modules directory from compilation
  ]
}
